global
    log /dev/log local0
    maxconn 2048
    user haproxy
    group haproxy
    daemon
    tune.ssl.default-dh-param 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    retries 3
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend http_front
    bind *:80
    redirect scheme https code 301 if !{ ssl_fc }

frontend https_front
    bind *:443 ssl crt /etc/ssl/private/www.gisadan.tech.pem
    default_backend http_back

backend http_back
    balance roundrobin
    server 6991-web-01 54.172.146.253:80 check
    server 6991-web-02 100.54.239.117:80 check
